# Copy this file to `.env` and fill in your keys.
# cp .env.example .env

# --- Required -----------------------------------------------------------
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Anthropic model configuration ---------------------------------------
# Sonnet is faster/cheaper — good for iterating. Switch to claude-opus-4-8 for
# maximum reasoning quality once you're ready for production-grade reports.
ANTHROPIC_MODEL=claude-sonnet-5
# One of: low | medium | high | xhigh | max
ANTHROPIC_EFFORT=high
MAX_AGENT_ITERATIONS=10
MAX_OUTPUT_TOKENS=8000

# --- Web search (optional but recommended) -------------------------------
# Without this, the agent falls back to mock/placeholder search results so
# the backend remains runnable out of the box. Get a free key at
# https://tavily.com
TAVILY_API_KEY=
SEARCH_RESULTS_PER_QUERY=5

# --- Server ---------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
# Comma-separated list of allowed frontend origins
CORS_ALLOW_ORIGINS_RAW=http://localhost:3000

TASK_TTL_SECONDS=3600
